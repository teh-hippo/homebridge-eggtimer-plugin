{
  "name": "homebridge-eggtimer-plugin",
  "displayName": "Homebridge Eggtimer Plugin",
  "version": "1.1.6",
  "description": "Egg Timers for Homebridge: https://github.com/nfarina/homebridge",
  "license": "MIT",
  "keywords": [
    "homebridge-plugin",
    "egg-timer",
    "eggtimer",
    "timer",
    "countdown",
    "delay",
    "automation",
    "homebridge",
    "persistent"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/teh-hippo/homebridge-eggtimer-plugin.git"
  },
  "bugs": {
    "url": "http://github.com/teh-hippo/homebridge-eggtimer-plugin/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/teh-hippo"
  },
  "main": "dist/accessory.js",
  "engines": {
    "node": ">=18.0.0",
    "homebridge": ">=1.3.5 || ^2.0.0-beta.0"
  },
  "scripts": {
    "lint": "eslint src",
    "lintAndFix": "eslint --fix src",
    "debug": "tsc && homebridge -I -D",
    "build": "rimraf ./dist && tsc",
    "prepublishOnly": "pnpm lint && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/async-lock": "^1.4.2",
    "@types/node": "^24.12.0",
    "@types/node-persist": "^3.1.8",
    "eslint": "^10.0.0",
    "homebridge": "^1.11.3",
    "rimraf": "^6.1.3",
    "semantic-release": "25.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "async-lock": "^1.4.1",
    "node-persist": "^4.0.4"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript-eslint>typescript": "*",
        "@typescript-eslint/eslint-plugin>typescript": "*",
        "@typescript-eslint/parser>typescript": "*",
        "@typescript-eslint/type-utils>typescript": "*",
        "@typescript-eslint/utils>typescript": "*",
        "@typescript-eslint/typescript-estree>typescript": "*",
        "@typescript-eslint/tsconfig-utils>typescript": "*",
        "@typescript-eslint/project-service>typescript": "*"
      }
    }
  }
}
